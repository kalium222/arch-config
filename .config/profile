# ---------------- functions ----------------

# yazi wrapper
if command -v yazi 2>&1 > /dev/null; then
    function yazi_wrapper() {
        local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
        yazi "$@" --cwd-file="$tmp"
        if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
            cd -- "$cwd"
        fi
        rm -f -- "$tmp"
    }
fi

if command -v zellij 2>&1 > /dev/null; then
