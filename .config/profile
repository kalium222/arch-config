passgen() {
    read -s MSG
    echo -n "$MSG" | openssl dgst -sha256 -binary | base64 | head -c 12 | awk '{print $0"K@!"}'
}

cheat() {
    curl -s "cheat.sh/$1" | {
        if command -v bat 2>&1 > /dev/null; then
            bat -p
        else
            less
        fi
    }
}

claudman() {
    local config=${XDG_CONFIG_HOME:-${HOME}/.config}/claude
    local cache=${XDG_CACHE_HOME:-${HOME}/.cache}/claude
    local state=${XDG_STATE_HOME:-${HOME}/.local/state}/.claude.json
    [ -d $config ] || mkdir -p $config
    [ -d $cache ] || mkdir -p $cache
    [ -f $state ] || touch $state

    podman run -it --rm \
        --name claude --hostname claude \
        -v .:/root/workspace \
        -v $state:/root/.claude.json \
        -v $config:/root/.claude \
        -v $cache:/root/.cache/claude \
        localhost/claude:latest
}

# ---------------- constants ----------------

# some aliases
alias v='nvim'
alias f='fastfetch'
alias y='yazi_wrapper'
alias z='zellij_wrapper'

# env
command -v nvim > /dev/null 2>&1 && export EDITOR='nvim'
command -v bat > /dev/null 2>&1 && export PAGER="bat -p"


if [ -x /usr/bin/micromamba ]; then
    # >>> mamba initialize >>>
    # !! Contents within this block are managed by 'micromamba shell init' !!
    # tweaked to this
    export MAMBA_EXE='/usr/bin/micromamba';
    export MAMBA_ROOT_PREFIX="$HOME/.local/share/mamba";
    __mamba_setup="$("$MAMBA_EXE" shell hook --shell $(basename "$SHELL") --root-prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
    if [ $? -eq 0 ]; then
        eval "$__mamba_setup"
    else
        alias micromamba="$MAMBA_EXE"  # Fallback on help from micromamba activate
    fi
    alias conda='micromamba'
    unset __mamba_setup
    # <<< mamba initialize <<<
fi


# ---------------- misc ----------------

__get_prompt_extra_info() {
    echo $(__get_conda_env)$(__get_nix_shell)
}

__get_nix_shell() {
    if [ -n "$IN_NIX_SHELL" ]; then
        echo "─{:${name}}"
    fi
}

__get_conda_env() {
    CONDA_SYMBOL=":"
    CONDA_ENV=""
    if [ -n "$CONDA_PREFIX" ]; then
        CONDA_DIR=$(basename $CONDA_PREFIX)
        if [ "$CONDA_DIR" == "anaconda" ]; then
            CONDA_ENV="base"
        else
            CONDA_ENV=$CONDA_DIR
        fi
        echo "─{${CONDA_SYMBOL}${CONDA_ENV}}"
    fi
}
